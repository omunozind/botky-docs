{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Botky",
  "colors": {
    "primary": "#042940",
    "light": "#DBF227",
    "dark": "#042940"
  },
  "background": {
    "dark": "#042940"
  },
  "appearance": {
    "default": "light"
  },
  "icons": {
    "library": "fontawesome"
  },
  "navigation": {
    "groups": [
      {
        "group": "Constructor de Flujos",
        "pages": [
          {
            "group": "Descripción general",
            "pages": [
              "flow-builder/overview",
              "flow-builder/field-variable",
              "flow-builder/publish-draft",
              "flow-builder/navigation-sidebar",
              "flow-builder/basic-operations"
            ]
          },
          {
            "group": "Subflujos",
            "pages": [
              "flow-builder/sub-flow",
              "flow-builder/workflow",
              "flow-builder/function-flow"
            ]
          },
          {
            "group": "Building Blocks / Pasos",
            "pages": [
              "flow-builder/send-message",
              "flow-builder/question",
              {
                "group": "Acción",
                "pages": [
                  "flow-builder/notifications",
                  {
                    "group": "Acciones avanzadas",
                    "pages": [
                      "flow-builder/external-request",
                      "flow-builder/smart-delay",
                      "flow-builder/javascript-function",
                      "flow-builder/send-sms-action",
                      "flow-builder/update-user-profile",
                      "flow-builder/trigger-workflow-action",
                      "flow-builder/rate-limit-attempts"
